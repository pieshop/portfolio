{
  "name": "portfolio-react-redux",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "author": "Stephen Hamilton",
  "scripts": {
    "serve": "node --env-file=.env server/index.js",
    "--  vite  --": "------------------------",
    "dev": "vite",
    "build:dev": "tsc && vite build --mode development",
    "build:stage": "tsc && vite build --mode staging",
    "build:prod": "tsc && vite build",
    "build": "tsc && vite build",
    "-- docker -": "------------------------",
    "docker:stop": "docker container stop ipStoryMiner || true",
    "docker:remove": "docker container rm ipStoryMiner || true",
    "docker:build:dev": "./build/docker-build.sh development ip-story-miner",
    "docker:build:stage": "./build/docker-build.sh staging ip-story-miner",
    "docker:build:prod": "./build/docker-build.sh production ip-story-miner",
    "docker:run": "docker run --env-file ./.env -p 3000:3000 -d --name brandEvaluation ip-story-miner",
    "++--------": "------------------------"
  },
  "dependencies": {
    "@aws-amplify/auth": "^6.6.2",
    "@aws-amplify/ui-react": "^6.5.5",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.2.1",
    "@react-pdf/renderer": "^4.3.0",
    "@reduxjs/toolkit": "^2.2.6",
    "aws-amplify": "^6.6.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "framer-motion": "^12.23.12",
    "jwt-decode": "^4.0.0",
    "radix-ui": "^1.1.3",
    "react": "^18.3.1",
    "react-collapsible": "^2.10.0",
    "react-dom": "^18.3.1",
    "react-filepond": "^7.1.2",
    "react-hotkeys-hook": "^5.1.0",
    "react-markdown": "^9.0.3",
    "react-redux": "^9.1.2",
    "react-router": "^7.5.3",
    "redux-logger": "^3.0.6",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.31.0",
    "@eslint/json": "^0.13.1",
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/redux-logger": "^3.0.13",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.15.0",
    "jiti": "^2.5.1",
    "prettier": "^3.4.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.38.0",
    "vite": "^6.0.1",
    "vite-plugin-html": "^3.2.2"
  },
  "engines": {
    "node": "^22.17.1"
  }
}
